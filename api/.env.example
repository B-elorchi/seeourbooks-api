# =============================================================================
# SeeOurBook — Summarizer API — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================


# ── Database backend ──────────────────────────────────────────────────────────
# "supabase" → hosted Supabase (default)
# "postgres" → direct PostgreSQL via asyncpg (local or remote)
DB_BACKEND=supabase

# ── Supabase (required when DB_BACKEND=supabase) ─────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── Postgres direct (required when DB_BACKEND=postgres) ──────────────────────
# DATABASE_URL=postgresql://postgres:password@localhost:5432/seeourbook


# ── AI providers ─────────────────────────────────────────────────────────────

# Anthropic (for Claude summarization models)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (for cover images with native gpt-image-1/dall-e-3/dall-e-2)
OPENAI_API_KEY=sk-...

# OpenRouter (routes to Claude, GPT, DALL-E etc. with one key)
# Get yours at https://openrouter.ai/keys
# Models via OpenRouter use the vendor/model prefix, e.g. "openai/dall-e-3"
OPENROUTER_API_KEY=sk-or-...

# Deepgram (Text-to-Speech — English + Arabic fallback)
# Get yours at https://console.deepgram.com
DEEPGRAM_API_KEY=...

# Cartesia (Text-to-Speech — Arabic, optional)
# Required only if you set TTS_PROVIDER_AR=cartesia in the admin panel.
# NOTE: Voice IDs are UUIDs, not model names. Find them at https://play.cartesia.ai
# CARTESIA_API_KEY=...

# ElevenLabs (Text-to-Speech, optional)
# ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_EN=...
# ELEVENLABS_VOICE_AR=...


# ── Book text files ───────────────────────────────────────────────────────────
TEXT_DIR=/path/to/text/files


# ── Storage ───────────────────────────────────────────────────────────────────
# Choose ONE storage backend.

# Option A — DigitalOcean Spaces (production)
STORAGE_PROVIDER=spaces
DO_SPACES_KEY=your_spaces_access_key
DO_SPACES_SECRET=your_spaces_secret_key
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=seeourbook
DO_SPACES_CDN_URL=https://seeourbook.nyc3.cdn.digitaloceanspaces.com

# Option B — MinIO (local development — see docker-compose below)
# To start MinIO locally:
#
#   docker run -d --name minio \
#     -p 9000:9000 -p 9001:9001 \
#     -e MINIO_ROOT_USER=minioadmin \
#     -e MINIO_ROOT_PASSWORD=minioadmin \
#     minio/minio server /data --console-address ":9001"
#
# Then open http://localhost:9001, log in (minioadmin / minioadmin),
# create a bucket named "seeourbook", and set its access policy to "public".
#
# STORAGE_PROVIDER=minio
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=seeourbook


# ── Optional model overrides (admin panel is the preferred way) ───────────────
# Cover image routing:
#   OpenAI models  (dall-e-3, gpt-image-1, dall-e-2)        → uses OPENAI_API_KEY
#   OpenRouter models (black-forest-labs/flux-1.1-pro, etc.) → uses OPENROUTER_API_KEY
# NOTE: openai/* via OpenRouter does NOT work for images — use the bare name (dall-e-3).
# MODEL_HAIKU=claude-haiku-4-5-20251001
# MODEL_SONNET=claude-sonnet-4-6
# MODEL_OPUS=claude-opus-4-7
# MODEL_MINDMAP=gpt-4.1-mini
# IMAGE_MODEL=dall-e-3
# IMAGE_QUALITY=standard
# IMAGE_SIZE=1024x1536

# ── Summary chunk size ────────────────────────────────────────────────────────
# CHUNK_SIZE_WORDS=1500
